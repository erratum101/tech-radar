# Пусто = запросы к /api с того же origin (Vercel, nginx, Vite proxy в dev).
# Для отдельного домена API: https://api.example.com
VITE_SHARE_API_BASE=

# Локальный API (npm run server / npm run dev:full)
PORT=3001
# HOST=0.0.0.0

# Vercel / Upstash Redis — подставляются при подключении интеграции в Vercel Dashboard
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
